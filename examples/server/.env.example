# Env for the reference relay server (examples/server/proxy.ts).
# This is for the EXAMPLE backend only — the published library never reads env.

# --- Voice (Gemini Live, the /live WebSocket) -------------------------------
# Required to relay real Gemini Live voice. Without it, /live closes with an error.
GEMINI_API_KEY=""
# Optional: Live preview models rotate; pin one without redeploying.
# GEMINI_LIVE_MODEL="gemini-3.1-flash-live-preview"

# --- Text (OpenAI-compatible /api/chat SSE proxy) ---------------------------
# Any OpenAI-compatible /chat/completions server (Ollama, LM Studio, vLLM,
# llama.cpp, OpenAI itself, ...). Required for /api/chat.
# Examples:
#   LM Studio:  http://localhost:1234/v1
#   Ollama:     http://localhost:11434/v1
#   OpenAI:     https://api.openai.com/v1
# OPENAI_BASE_URL="http://localhost:1234/v1"
# OPENAI_API_KEY=""           # often unneeded for local servers
# OPENAI_MODEL="gpt-4o-mini"  # or your local model id

# --- Server ------------------------------------------------------------------
# PORT="3000"
# MAX_SESSIONS_PER_IP="3"
