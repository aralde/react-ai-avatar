{
  "name": "react-realtime-avatar",
  "version": "1.1.0",
  "description": "A presentational React avatar for realtime LLM voice UIs — you bring the connection, it brings the face.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/lib/index.cjs",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/lib/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs"
    },
    "./vrm": {
      "types": "./dist/lib/lib/vrm.d.ts",
      "import": "./dist/lib/vrm.js",
      "require": "./dist/lib/vrm.cjs"
    },
    "./style.css": "./dist/lib/react-realtime-avatar.css"
  },
  "files": [
    "dist/lib"
  ],
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "build:lib": "vite build --config vite.config.lib.ts && tsc --project tsconfig.lib.json",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@pixiv/three-vrm": "^3.0.0",
    "@react-three/drei": "^9.0.0 || ^10.0.0",
    "@react-three/fiber": "^8.0.0 || ^9.0.0",
    "motion": "^11.0.0 || ^12.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "three": ">=0.160.0"
  },
  "peerDependenciesMeta": {
    "@pixiv/three-vrm": {
      "optional": true
    },
    "@react-three/drei": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@google/genai": "^1.29.0",
    "@pixiv/three-vrm": "^3.5.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "dotenv": "^17.2.3",
    "esbuild": "^0.28.0",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.1.14",
    "three": "^0.184.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.6",
    "ws": "^8.21.0"
  }
}
